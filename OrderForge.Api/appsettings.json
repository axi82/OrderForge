{
  "AllowedHosts": "*",
  "Seq": {
    "ServerUrl": ""
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Enrichers.Environment",
      "Serilog.Enrichers.Thread"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/orderforge-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "OrderForge.Api"
    }
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=orderforge;Username=orderforge;Password=orderforge"
  },
  "Authentication": {
    "Authority": "",
    "Audience": "orderforge-api"
  },
  "KeycloakAdmin": {
    "BaseUrl": "http://localhost:8081",
    "Realm": "orderforge",
    "ClientId": "orderforge-admin-api",
    "ClientSecret": ""
  },
  "KeycloakPasswordGrant": {
    "ClientId": "admin-cli",
    "ClientSecret": ""
  },
  "Cors": {
    "Origins": [ "https://localhost:5001", "http://localhost:5000" ]
  }
}
