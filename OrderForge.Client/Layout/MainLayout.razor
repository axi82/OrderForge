@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col bg-slate-50">
    <NavMenu />

    <AuthorizeView>
        <Authorized>
            <div class="border-b border-slate-200 bg-white">
                <div class="mx-auto max-w-screen-2xl px-4 py-2 sm:px-6 lg:px-8">
                    <p class="text-sm text-slate-600">
                        <span class="font-medium text-slate-900">@GreetingPrefix()</span>, <span class="text-slate-800">@DisplayName(context)</span>
                    </p>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <main class="mx-auto w-full max-w-screen-2xl flex-1 px-4 py-8 sm:px-6 lg:px-8">
        <article class="content">
            @Body
        </article>
    </main>

    <footer class="mt-auto border-t border-slate-200 bg-white">
        <div class="mx-auto flex max-w-screen-2xl flex-col gap-3 px-4 py-6 sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
            <p class="text-sm text-slate-500">
                © @DateTime.UtcNow.Year Order Forge. B2B ordering portal.
            </p>
            <AuthorizeView Policy="@AuthorizationPolicies.SupplierAdmin">
                <Authorized>
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-slate-500">
                        <span class="font-medium text-slate-600">Admin tools</span>
                        <a class="text-link hover:text-primary" href="admin/companies">Companies</a>
                        <a class="text-link hover:text-primary" href="admin/companies/create">Create company</a>
                        <a class="text-link hover:text-primary" href="admin/users">Users</a>
                        <a class="text-link hover:text-primary" href="admin/users/invite">Invite user</a>
                        <a class="text-link hover:text-primary" href="organisations-test">Organisations (API test)</a>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>
    </footer>
</div>

@code {
    private static string GreetingPrefix() =>
        DateTime.UtcNow.Hour switch
        {
            < 12 => "Good morning",
            < 18 => "Good afternoon",
            _ => "Good evening",
        };

    private static string? DisplayName(AuthenticationState auth) =>
        auth.User.FindFirst("name")?.Value
        ?? auth.User.FindFirst("given_name")?.Value
        ?? auth.User.FindFirst("preferred_username")?.Value
        ?? auth.User.Identity?.Name;
}
