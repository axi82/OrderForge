@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using OrderForge.Client

<AuthorizeView>
    <Authorized Context="authState">
        @if (IsSupplierPersona(authState.User))
        {
            <LayoutView Layout="@typeof(SupplierLayout)">@Body</LayoutView>
        }
        else if (authState.User.IsInRole(AuthorizationPolicies.Customer)
                 || authState.User.IsInRole("CompanyAdmin"))
        {
            <LayoutView Layout="@typeof(CustomerLayout)">@Body</LayoutView>
        }
        else
        {
            <div class="flex min-h-screen flex-col bg-slate-50">
                <header class="sticky top-0 z-50 bg-primary shadow-md">
                    <div class="mx-auto flex max-w-screen-2xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
                        <a
                            class="shrink-0 text-lg font-semibold tracking-tight text-white no-underline hover:text-white"
                            href="@Routes.App.Root"
                        >
                            Order Forge
                        </a>
                        <SignOutButton Variant="SignOutButtonVariant.PrimaryHeaderToolbar" />
                    </div>
                </header>
                <main class="mx-auto w-full max-w-screen-2xl flex-1 px-4 py-8 sm:px-6 lg:px-8">@Body</main>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private static bool IsSupplierPersona(System.Security.Claims.ClaimsPrincipal user) =>
        user.IsInRole(AuthorizationPolicies.SupplierAdmin) || user.IsInRole("SupplierViewer");
}