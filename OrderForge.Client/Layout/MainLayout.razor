@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<AuthorizeView>
    <Authorized Context="authState">
        @if (IsSupplierPersona(authState.User))
        {
            <LayoutView Layout="@typeof(SupplierLayout)">@Body</LayoutView>
        }
        else if (authState.User.IsInRole(AuthorizationPolicies.Customer)
                 || authState.User.IsInRole("CompanyAdmin"))
        {
            <LayoutView Layout="@typeof(CustomerLayout)">@Body</LayoutView>
        }
        else
        {
            <main class="mx-auto max-w-screen-2xl px-4 py-8">@Body</main>
        }
    </Authorized>
    <NotAuthorized>
        <RedirectToLogin />
    </NotAuthorized>
</AuthorizeView>

@code {
    private static bool IsSupplierPersona(System.Security.Claims.ClaimsPrincipal user) =>
        user.IsInRole(AuthorizationPolicies.SupplierAdmin) || user.IsInRole("SupplierViewer");
}