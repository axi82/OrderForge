@inherits LayoutComponentBase

<div class="flex min-h-screen flex-col bg-slate-50">
    <header class="sticky top-0 z-50 bg-primary shadow-md">
        <div class="mx-auto flex max-w-screen-2xl items-center px-4 py-3 sm:px-6 lg:px-8">
            <a
                class="shrink-0 text-lg font-semibold tracking-tight text-white no-underline hover:text-white"
                href="@Routes.App.Root"
            >
                Order Forge
            </a>
        </div>
    </header>

    <div class="flex min-h-0 flex-1 flex-col md:flex-row">
        <aside
            class="w-full shrink-0 border-b border-slate-200 bg-white md:w-64 md:border-e md:border-b-0"
            aria-label="Supplier navigation"
        >
            <div class="px-4 py-4 md:sticky md:top-14 md:h-[calc(100vh-3.5rem)] md:overflow-y-auto">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">Supplier Dashboard</p>

                <AuthorizeView Policy="@AuthorizationPolicies.SupplierStaff">
                    <Authorized>
                        <nav class="mt-6 flex flex-col gap-2" aria-label="Admin">
                            <NavLink
                                href="@Routes.Admin.Products"
                                class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-slate-800 no-underline transition-colors hover:bg-slate-100"
                                ActiveClass="!bg-accent !text-white shadow-sm hover:!bg-accent-dark"
                                Match="NavLinkMatch.Prefix"
                            >
                                <svg
                                    class="h-5 w-5 shrink-0"
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="m21 7.5-9-5.25L3 7.5m18 0-9-5.25m9 9.75-9-5.25m9 5.25v9.75m-18-9.75v9.75m0-9.75-9-5.25M12 12 3 7.5m9 4.5 9-5.25M12 12v9.75"
                                    />
                                </svg>
                                Products
                            </NavLink>
                            <NavLink
                                href="@Routes.Admin.Companies"
                                class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-slate-800 no-underline transition-colors hover:bg-slate-100"
                                ActiveClass="!bg-accent !text-white shadow-sm hover:!bg-accent-dark"
                                Match="NavLinkMatch.Prefix"
                            >
                                <svg
                                    class="h-5 w-5 shrink-0"
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M3.75 21h16.5M4.5 3h15M5.25 3v18m13.5-18v18M9 6.75h1.5m-1.5 3h1.5m-1.5 3h1.5m3-6H15m-1.5 3H15m-1.5 3H15M9 21v-3.375c0-.621.504-1.125 1.125-1.125h3.75c.621 0 1.125.504 1.125 1.125V21"
                                    />
                                </svg>
                                Companies
                            </NavLink>
                            <NavLink
                                href="@Routes.Admin.Users"
                                class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-slate-800 no-underline transition-colors hover:bg-slate-100"
                                ActiveClass="!bg-accent !text-white shadow-sm hover:!bg-accent-dark"
                                Match="NavLinkMatch.Prefix"
                            >
                                <svg
                                    class="h-5 w-5 shrink-0"
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="1.5"
                                    stroke="currentColor"
                                    aria-hidden="true"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"
                                    />
                                </svg>
                                Admin Users
                            </NavLink>
                        </nav>
                    </Authorized>
                </AuthorizeView>
            </div>
        </aside>

        <div class="flex min-w-0 flex-1 flex-col">
            <header class="border-b border-slate-200 bg-white px-4 py-3">
                <p class="text-sm font-medium text-slate-900">Supplier Dashboard</p>
            </header>
            <main class="mx-auto w-full max-w-screen-2xl flex-1 px-4 py-8 sm:px-6 lg:px-8">
                @Body
            </main>
        </div>
    </div>
</div>
