@using OrderForge.Client
pissy pants
<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">OrderForge</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
             
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="dashboard">
                <span class="bi bi-speedometer2" aria-hidden="true"></span> Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="organisations-test">
                <span class="bi bi-building" aria-hidden="true"></span> Organisations test
            </NavLink>
        </div>
        <AuthorizeView Policy="@AuthorizationPolicies.SupplierStaff">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/companies">
                        <span class="bi bi-briefcase" aria-hidden="true"></span> Companies (admin)
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthorizationPolicies.SupplierAdmin">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/companies/create">
                        <span class="bi bi-plus-circle" aria-hidden="true"></span> Create company
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <AuthorizeView Policy="@AuthorizationPolicies.InviteUsers">
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="admin/users/invite">
                        <span class="bi bi-person-plus" aria-hidden="true"></span> Invite user
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>
        <div class="nav-item px-3 border-top border-secondary mt-2 pt-2">
            <AuthorizeView>
                <Authorized>
                    <div class="small text-white-50 px-3 mb-1 text-truncate" title="@UserEmail(context)">
                        @UserEmail(context)
                    </div>
                    <NavLink class="nav-link" href="authentication/logout">
                        Sign out
                    </NavLink>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="nav-link" href="login">
                        Sign in
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

@code {
    private static string? UserEmail(AuthenticationState context) =>
        context.User.FindFirst("email")?.Value
        ?? context.User.FindFirst("preferred_username")?.Value
        ?? context.User.Identity?.Name;

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
