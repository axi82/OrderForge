@using OrderForge.Client
@inject NavigationManager Navigation

<div
    class="top-row flex min-h-14 items-center bg-black/40 ps-3 text-white"
>
    <div class="flex w-full max-w-full items-center justify-between pr-2">
        <a class="text-lg font-semibold text-white no-underline hover:text-white" href=""
            >OrderForge</a
        >
        <button
            type="button"
            title="Navigation menu"
            class="min-[641px]:hidden rounded-md p-2 text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/40"
            @onclick="ToggleNavMenu"
        >
            <span class="sr-only">Open menu</span>
            <svg
                class="h-6 w-6"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
                />
            </svg>
        </button>
    </div>
</div>

<div
    class="@NavScrollableClass nav-scrollable"
    @onclick="ToggleNavMenu"
>
    <nav class="flex flex-col pb-4">
        <div class="nav-item px-3 pt-4">
            <NavLink
                class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                href=""
                Match="NavLinkMatch.All"
                ActiveClass="!bg-white/40 !text-white"
            >
                <svg
                    class="h-5 w-5 shrink-0"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"
                    />
                </svg>
                Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink
                class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                href="dashboard"
                ActiveClass="!bg-white/40 !text-white"
            >
                <svg
                    class="h-5 w-5 shrink-0"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"
                    />
                </svg>
                Dashboard
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink
                class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                href="organisations-test"
                ActiveClass="!bg-white/40 !text-white"
            >
                <svg
                    class="h-5 w-5 shrink-0"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008H16.5v-.008Zm0 3h.008v.008H16.5v-.008Zm0 3h.008v.008H16.5v-.008Z"
                    />
                </svg>
                Organisations test
            </NavLink>
        </div>

        <AuthorizeView Policy="@AuthorizationPolicies.SupplierAdmin">
            <Authorized>
                <div class="nav-item px-3">
                    <button
                        type="button"
                        class="flex h-12 w-full items-center gap-3 rounded-md border-0 bg-transparent px-3 text-left text-sm text-[#d7d7d7] hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                        @onclick="ToggleAdminMenu"
                        @onclick:stopPropagation="true"
                    >
                        <svg
                            class="h-5 w-5 shrink-0"
                            xmlns="http://www.w3.org/2000/svg"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke-width="1.5"
                            stroke="currentColor"
                            aria-hidden="true"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"
                            />
                        </svg>
                        Admin
                        @if (adminMenuExpanded)
                        {
                            <svg
                                class="ms-auto h-4 w-4 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="m19.5 8.25-7.5 7.5-7.5-7.5"
                                />
                            </svg>
                        }
                        else
                        {
                            <svg
                                class="ms-auto h-4 w-4 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="m8.25 4.5 7.5 7.5-7.5 7.5"
                                />
                            </svg>
                        }
                    </button>
                </div>

                <div class="admin-submenu @(adminMenuExpanded ? "expanded" : "")">
                    <div class="nav-item px-3 ps-8">
                        <NavLink
                            class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                            href="admin/companies/create"
                            ActiveClass="!bg-white/40 !text-white"
                        >
                            <svg
                                class="h-5 w-5 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                                />
                            </svg>
                            Create company
                        </NavLink>
                    </div>

                    <div class="nav-item px-3 ps-8">
                        <NavLink
                            class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                            href="admin/users"
                            ActiveClass="!bg-white/40 !text-white"
                        >
                            <svg
                                class="h-5 w-5 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.5M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"
                                />
                            </svg>
                            Manage users
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink
                            class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                            href="admin/companies"
                            ActiveClass="!bg-white/40 !text-white"
                        >
                            <svg
                                class="h-5 w-5 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z"
                                />
                            </svg>
                            Companies (admin)
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <NavLink
                            class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                            href="admin/users/invite"
                            ActiveClass="!bg-white/40 !text-white"
                        >
                            <svg
                                class="h-5 w-5 shrink-0"
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                aria-hidden="true"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z"
                                />
                            </svg>
                            Invite user
                        </NavLink>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="nav-item mt-2 border-t border-white/20 px-3 pt-2">
            <AuthorizeView>
                <Authorized>
                    <div
                        class="mb-1 truncate px-3 text-xs text-white/50"
                        title="@UserEmail(context)"
                    >
                        @UserEmail(context)
                    </div>
                    <button
                        type="button"
                        class="flex h-12 w-full items-center rounded-md border-0 bg-transparent px-3 py-2 text-left text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                        @onclick="SignOut"
                        @onclick:stopPropagation="true"
                    >
                        Sign out
                    </button>
                </Authorized>
                <NotAuthorized>
                    <NavLink
                        class="flex h-12 items-center gap-3 rounded-md px-3 text-sm text-[#d7d7d7] no-underline hover:bg-white/10 hover:text-white focus:outline-none focus:ring-2 focus:ring-white/30"
                        href="login"
                        ActiveClass="!bg-white/40 !text-white"
                    >
                        Sign in
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

@code {
    private static string? UserEmail(AuthenticationState context) =>
        context.User.FindFirst("email")?.Value
        ?? context.User.FindFirst("preferred_username")?.Value
        ?? context.User.Identity?.Name;

    private bool collapseNavMenu = true;

    private string NavScrollableClass =>
        collapseNavMenu ? "hidden min-[641px]:block" : "block min-[641px]:block";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private bool adminMenuExpanded;

    private void ToggleAdminMenu()
    {
        adminMenuExpanded = !adminMenuExpanded;
    }

    private void SignOut()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}
