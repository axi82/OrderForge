@using OrderForge.Client
@inject NavigationManager Navigation

<header class="sticky top-0 z-50 bg-primary shadow-md">
    <div class="mx-auto flex max-w-screen-2xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8">
        <a
            class="shrink-0 text-lg font-semibold tracking-tight text-white no-underline hover:text-white"
            href=""
            @onclick="CloseMobile"
        >
            Order Forge
        </a>

        <button
            type="button"
            class="inline-flex rounded-lg p-2 text-white hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/40 md:hidden"
            @onclick="ToggleMobile"
            aria-expanded="@mobileOpen"
            aria-controls="forge-mobile-nav"
        >
            <span class="sr-only">Toggle menu</span>
            @if (mobileOpen)
            {
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                </svg>
            }
            else
            {
                <svg class="h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            }
        </button>

        <nav class="hidden items-center gap-1 md:flex" aria-label="Primary">
            <AuthorizeView>
                <Authorized>
                    <NavLink class="@NavInactive" href="" Match="NavLinkMatch.All" ActiveClass="@NavActive" @onclick="CloseMobile">Account</NavLink>
                    <NavLink class="@NavInactive" href="catalog" ActiveClass="@NavActive" @onclick="CloseMobile">Catalogue</NavLink>
                    <NavLink class="@NavInactive" href="orders" ActiveClass="@NavActive" @onclick="CloseMobile">My orders</NavLink>
                    <NavLink class="@($"{NavInactive} inline-flex items-center gap-2")" href="cart" ActiveClass="@NavActive" @onclick="CloseMobile">
                        <span>Cart</span>
                        @if (CartBadgeCount > 0)
                        {
                            <span class="inline-flex min-w-[1.25rem] items-center justify-center rounded-full bg-accent px-1.5 py-0.5 text-xs font-semibold text-white">@CartBadgeCount</span>
                        }
                    </NavLink>
                    <button
                        type="button"
                        class="ms-1 rounded-lg px-3 py-2 text-sm font-medium text-white/90 hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
                        @onclick="SignOut"
                    >
                        Sign out
                    </button>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="@NavInactive" href="login" ActiveClass="@NavActive">Sign in</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </div>

    <div
        id="forge-mobile-nav"
        class="@(mobileOpen ? "block" : "hidden") border-t border-white/10 md:hidden"
    >
        <nav class="flex flex-col gap-1 px-4 py-3" aria-label="Mobile primary">
            <AuthorizeView>
                <Authorized>
                    <NavLink class="@MobileLink" href="" Match="NavLinkMatch.All" ActiveClass="@NavActive" @onclick="CloseMobile">Account</NavLink>
                    <NavLink class="@MobileLink" href="catalog" ActiveClass="@NavActive" @onclick="CloseMobile">Catalogue</NavLink>
                    <NavLink class="@MobileLink" href="orders" ActiveClass="@NavActive" @onclick="CloseMobile">My orders</NavLink>
                    <NavLink class="@($"{MobileLink} inline-flex items-center gap-2")" href="cart" ActiveClass="@NavActive" @onclick="CloseMobile">
                        <span>Cart</span>
                        @if (CartBadgeCount > 0)
                        {
                            <span class="inline-flex min-w-[1.25rem] items-center justify-center rounded-full bg-accent px-1.5 py-0.5 text-xs font-semibold text-white">@CartBadgeCount</span>
                        }
                    </NavLink>
                    <div class="my-2 border-t border-white/10 pt-2">
                        <AuthorizeView Policy="@AuthorizationPolicies.SupplierAdmin">
                            <Authorized Context="adminAuth">
                                <p class="mb-1 px-3 text-xs font-semibold uppercase tracking-wide text-white/60">Admin</p>
                                <a class="block rounded-lg px-3 py-2 text-sm text-white/90 hover:bg-white/10" href="admin/companies" @onclick="CloseMobile">Companies</a>
                                <a class="block rounded-lg px-3 py-2 text-sm text-white/90 hover:bg-white/10" href="admin/users/invite" @onclick="CloseMobile">Invite user</a>
                            </Authorized>
                        </AuthorizeView>
                        <button
                            type="button"
                            class="mt-2 w-full rounded-lg px-3 py-2 text-left text-sm text-white/90 hover:bg-white/10"
                            @onclick="SignOut"
                        >
                            Sign out
                        </button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <NavLink class="@MobileLink" href="login" @onclick="CloseMobile">Sign in</NavLink>
                </NotAuthorized>
            </AuthorizeView>
        </nav>
    </div>
</header>

@code {
    private const string NavInactive =
        "rounded-lg px-3 py-2 text-sm font-medium text-white/90 no-underline hover:bg-white/10 focus:outline-none focus:ring-2 focus:ring-white/30";

    private const string NavActive = "bg-white/15 text-white";

    private const string MobileLink =
        "rounded-lg px-3 py-3 text-sm font-medium text-white/90 no-underline hover:bg-white/10";

    private const int CartBadgeCount = 3;

    private bool mobileOpen;

    private void ToggleMobile() => mobileOpen = !mobileOpen;

    private void CloseMobile() => mobileOpen = false;

    private void SignOut()
    {
        CloseMobile();
        Navigation.NavigateToLogout("authentication/logout");
    }
}
