@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).TrimStart('/');
        if (string.IsNullOrEmpty(relative))
        {
            relative = "dashboard";
        }

        Navigation.NavigateTo("authentication/login?returnUrl=" + Uri.EscapeDataString(relative));
    }
}
