@page "/admin/companies/create"
@attribute [Authorize(Policy = AuthorizationPolicies.SupplierAdmin)]
@inject IAdminApiClient AdminApi

<PageTitle>Create company</PageTitle>

<h1 class="mb-3 text-2xl font-semibold">Create customer company</h1>

<p class="text-sm text-gray-500">
    Creates a Keycloak organisation (requires at least one internet domain) and a linked company record.
</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-800" role="alert">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="mt-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-green-800" role="alert">
        @successMessage
    </div>
}

<EditForm Model="model" OnValidSubmit="OnSubmitAsync">
    <div class="-mx-2 flex flex-wrap gap-y-2">
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Name *</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.Name"
            />
        </div>
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Trading as</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.TradingAs"
            />
        </div>
        <div class="w-full px-2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Organization email domain</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.OrganizationDomain"
                placeholder="e.g. acme.com"
            />
            <p class="mt-1 text-xs text-gray-500">
                Used by Keycloak to relate users (email) to this company. Leave blank to use a generated placeholder domain.
            </p>
        </div>
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Company number</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.CompanyNumber"
            />
        </div>
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">VAT number</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.VatNumber"
            />
        </div>
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Account number</label>
            <InputText
                class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.AccountNumber"
            />
        </div>
        <div class="w-full px-2 md:w-1/2">
            <label class="mb-1 block text-sm font-medium text-gray-700">Status</label>
            <InputSelect
                class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                @bind-Value="model.Status"
            >
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </InputSelect>
        </div>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3">
        <button
            type="submit"
            class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-accent-dark focus:outline-none focus:ring-2 focus:ring-accent-ring disabled:opacity-50"
            disabled="@saving"
        >
            Create
        </button>
        <a class="text-primary hover:text-primary-dark hover:underline" href="@Routes.Admin.Companies">Back to list</a>
    </div>
</EditForm>

@code {
    private readonly CreateCustomerCompanyRequest model = new();
    private string? errorMessage;
    private string? successMessage;
    private bool saving;

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        successMessage = null;
        saving = true;
        try
        {
            var created = await AdminApi.CreateCompanyAsync(model);
            successMessage = $"Created company #{created.Id} (Keycloak org: {created.KeycloakOrganizationId}).";
            model.Name = string.Empty;
            model.TradingAs = null;
            model.OrganizationDomain = null;
            model.CompanyNumber = null;
            model.VatNumber = null;
            model.AccountNumber = null;
            model.Status = "Active";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
