@page "/admin/users/invite"
@attribute [Authorize(Policy = AuthorizationPolicies.InviteUsers)]
@inject IAdminApiClient AdminApi

<PageTitle>Invite user</PageTitle>

<h1 class="mb-3 text-2xl font-semibold">Invite user to company</h1>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-800" role="alert">
        @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="mt-4 rounded-md border border-green-200 bg-green-50 px-4 py-3 text-green-800" role="alert">
        @successMessage
    </div>
}

@if (loading)
{
    <p class="text-gray-500">Loading companies…</p>
}
else
{
    <EditForm Model="model" OnValidSubmit="OnSubmitAsync">
        <div class="-mx-2 flex flex-wrap gap-y-2">
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Company *</label>
                <InputSelect
                    class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.OrganisationId"
                >
                    <option value="0">— Select —</option>
                    @foreach (var c in companies)
                    {
                        <option value="@c.Id">@c.Name (@c.Id)</option>
                    }
                </InputSelect>
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Email *</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.Email"
                />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">First name</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.FirstName"
                />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Last name</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.LastName"
                />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Realm role *</label>
                <InputSelect
                    class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.RealmRoleName"
                >
                    <option value="Customer">Customer</option>
                    <option value="CompanyAdmin">CompanyAdmin</option>
                </InputSelect>
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Temporary password (optional)</label>
                <InputText
                    type="password"
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="model.TemporaryPassword"
                />
                <div class="mt-1 text-sm text-gray-500">
                    If empty, user must use Keycloak reset / email actions.
                </div>
            </div>
        </div>
        <div class="mt-3">
            <button
                type="submit"
                class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-accent-dark focus:outline-none focus:ring-2 focus:ring-accent-ring disabled:opacity-50"
                disabled="@saving"
            >
                Send invite
            </button>
        </div>
    </EditForm>
}

@code {
    private readonly List<OrganisationDto> companies = [];
    private readonly InviteUserRequest model = new();
    private bool loading = true;
    private bool saving;
    private string? errorMessage;
    private string? successMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            companies.Clear();
            companies.AddRange(await AdminApi.GetCompaniesAsync());
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        successMessage = null;
        if (model.OrganisationId <= 0)
        {
            errorMessage = "Select a company.";
            return;
        }

        saving = true;
        try
        {
            var res = await AdminApi.InviteUserAsync(model);
            successMessage = $"Invited {res.Email} (username {res.Username}, id {res.UserId}).";
            model.Email = string.Empty;
            model.FirstName = null;
            model.LastName = null;
            model.TemporaryPassword = null;
            model.RealmRoleName = "Customer";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
