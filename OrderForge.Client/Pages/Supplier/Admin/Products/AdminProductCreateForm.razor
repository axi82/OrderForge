@using Microsoft.AspNetCore.Components.Forms

<div>
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-800" role="alert">
            @ErrorMessage
        </div>
    }
    <EditForm Model="Model" OnSubmit="HandleSubmitAsync">
        <DataAnnotationsValidator />
        <div class="-mx-2 flex flex-wrap gap-y-2">
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700" for="admin-product-modal-sku">SKU *</label>
                <InputText
                    id="admin-product-modal-sku"
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.Sku"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.Sku" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Product code *</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.ProductCode"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.ProductCode" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Name *</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.Name"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.Name" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Short description *</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.ShortDescription"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.ShortDescription" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Description</label>
                <InputTextArea
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.Description"
                    rows="4"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.Description" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Brand</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.Brand"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.Brand" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Commodity code</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.CommodityCodeDescription"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.CommodityCodeDescription" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Supplier A/C</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.SupplierAccountCode"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.SupplierAccountCode" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Part no.</label>
                <InputText
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.PartNumber"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.PartNumber" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="w-full px-2 md:w-1/5">
                <label class="mb-1 block text-sm font-medium text-gray-700">Qty in stock</label>
                <InputNumber
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind-Value="Model.QuantityInStock"
                    disabled="@Saving"
                />
                <ValidationMessage For="() => Model.QuantityInStock" class="mt-1 block text-sm text-red-600" />
            </div>
            <div class="flex w-full items-center px-2 pt-2 md:w-1/4">
                <label class="flex cursor-pointer items-center gap-2 text-sm font-medium text-gray-700">
                    <InputCheckbox @bind-Value="Model.IsActive" disabled="@Saving" />
                    Active
                </label>
            </div>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
            <button
                type="button"
                class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 disabled:opacity-50"
                disabled="@Saving"
                @onclick="HandleCancelAsync">
                Cancel
            </button>
            <button
                type="submit"
                class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-accent-dark focus:outline-none focus:ring-2 focus:ring-accent-ring disabled:opacity-50"
                disabled="@Saving"
            >
                @(Saving ? "Saving…" : "Add Product")
            </button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter, EditorRequired]
    public CreateProductRequest Model { get; set; } = default!;

    [Parameter]
    public string? ErrorMessage { get; set; }

    [Parameter]
    public bool Saving { get; set; }

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    private async Task HandleSubmitAsync(EditContext editContext)
    {
        Model.NormalizeStringsForCreate();
        await InvokeAsync(StateHasChanged);
        if (editContext.Validate())
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private Task HandleCancelAsync() => OnCancel.InvokeAsync();
}
