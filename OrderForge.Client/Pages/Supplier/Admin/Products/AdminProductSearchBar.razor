<div class="mb-4 rounded-lg border border-gray-200 bg-gray-50 p-3 shadow-sm sm:p-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end">
        <div class="flex min-w-[12rem] flex-1 flex-col gap-1">
            <label class="text-xs font-medium text-gray-600" for="product-search">Search</label>
            <input id="product-search"
                   class="rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                   value="@SearchText"
                   @oninput="OnSearchInputAsync"
                   @onkeydown="OnSearchKeyDownAsync"
                   placeholder="SKU, product code, name, part no., barcode…"
                   disabled="@Loading" />
        </div>
        <button type="button"
                class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 disabled:opacity-50"
                disabled="@Loading"
                @onclick="SearchAsync">
            Search
        </button>
        @if (ShowAddProduct)
        {
            <button type="button"
                    @ref="_addProductButtonRef"
                    class="inline-flex items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-accent-dark focus:outline-none focus:ring-2 focus:ring-accent-ring disabled:opacity-50"
                    disabled="@Loading"
                    @onclick="AddProductAsync">
                Add Product
            </button>
        }
    </div>
</div>

@code {
    private ElementReference _addProductButtonRef;

    [Parameter]
    public string SearchText { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SearchTextChanged { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public EventCallback OnSearch { get; set; }

    [Parameter]
    public bool ShowAddProduct { get; set; }

    [Parameter]
    public EventCallback OnAddProduct { get; set; }

    public ValueTask FocusAddProductButtonAsync() => _addProductButtonRef.FocusAsync();

    private Task OnSearchInputAsync(ChangeEventArgs e) =>
        SearchTextChanged.InvokeAsync(e.Value?.ToString() ?? string.Empty);

    private async Task OnSearchKeyDownAsync(KeyboardEventArgs e)
    {
        if (Loading || !string.Equals(e.Key, "Enter", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        await SearchAsync();
    }

    private Task SearchAsync() => OnSearch.InvokeAsync();

    private Task AddProductAsync() => OnAddProduct.InvokeAsync();
}
