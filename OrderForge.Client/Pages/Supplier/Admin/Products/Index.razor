@page "/admin/products"
@attribute [Authorize(Policy = AuthorizationPolicies.SupplierStaff)]
@inject IAdminApiClient AdminApi
@inject IJSRuntime Js
@inject IAuthorizationService AuthorizationService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Products (admin)</PageTitle>

<div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <div>
        <h1 class="text-2xl font-semibold">Products</h1>
        <p class="text-sm text-gray-500">Catalog items available for ordering.</p>
    </div>
</div>

@if (isSupplierAdmin)
{
    <dialog @ref="_addProductDialog"
            class="w-[min(100%,42rem)] max-w-full rounded-xl border-0 bg-transparent p-0 shadow-none backdrop:bg-black/40"
            @oncancel="OnAddProductDialogCancelAsync"
            @onclick="OnAddProductDialogBackdropAsync">
        <div class="flex max-h-[min(90dvh,48rem)] flex-col overflow-hidden rounded-lg border border-gray-200 bg-white shadow-xl" @onclick:stopPropagation="true">
            <div class="border-b border-gray-200 bg-gray-50 px-4 py-3 font-medium text-gray-900">
                Add product
            </div>
            <div class="overflow-y-auto p-4">
                <AdminProductCreateForm
                    Model="@createModel"
                    ErrorMessage="@createErrorMessage"
                    Saving="@saving"
                    OnValidSubmit="@OnCreateSubmitAsync"
                    OnCancel="@DismissAddProductDialogAsync" />
            </div>
        </div>
    </dialog>
}

<AdminProductSearchBar
    @ref="_searchBar"
    @bind-SearchText="searchText"
    Loading="@loading"
    OnSearch="@ApplySearchAsync"
    ShowAddProduct="@isSupplierAdmin"
    OnAddProduct="@OpenAddProductDialogAsync" />

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-800" role="alert">
        @errorMessage
    </div>
}

@if (loading)
{
    <p class="text-gray-500">Loading…</p>
}
else if (result is not null && result.TotalCount == 0)
{
    <p class="text-gray-500">No products yet.</p>
}
else if (result is not null)
{
    <AdminProductTable
        Items="@result.Items"
        DeletingId="@deletingId"
        OnDeleteRequested="@DeleteAsync" />

    <AdminProductPagination
        ShowingStart="@ShowingStart"
        ShowingEnd="@ShowingEnd"
        TotalCount="@result.TotalCount"
        CurrentPage="@(page)"
        PageSize="@pageSize"
        MaxPage="@MaxPage"
        Loading="@loading"
        OnPageSizeChanged="@OnPageSizeChanged"
        OnPrevious="@GoToPrevPageAsync"
        OnNext="@GoToNextPageAsync" />
}
