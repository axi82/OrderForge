@page "/"
@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ITradeOrdersApiClient TradeOrdersApi

<PageTitle>Account</PageTitle>

<div class="mb-10">
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">Dashboard</h1>
    <p class="mt-2 text-slate-600">Overview of your account and recent ordering activity.</p>
</div>

<div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    <KpiCard Title="Open orders" Value="@openOrders.ToString()" Note="Awaiting delivery or confirmation" />
    <KpiCard Title="Spend (30 days)" Value="@spend30.ToString("C")" Note="Rolling total" />
    <KpiCard Title="Saved baskets" Value="1" Note="Draft carts not submitted" />
    <KpiCard Title="Credit available" Value="@creditAvailable.ToString("C")" Note="Subject to terms" />
</div>

<div class="mt-10 grid gap-8 lg:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Quick links</h2>
        <ul class="mt-4 space-y-2">
            <li>
                <a class="text-link font-medium hover:text-primary" href="@Routes.Store.Catalog">Browse catalogue</a>
            </li>
            <li>
                <a class="text-link font-medium hover:text-primary" href="@Routes.Store.Cart">View cart</a>
            </li>
            <li>
                <a class="text-link font-medium hover:text-primary" href="@Routes.Store.Orders">Order history</a>
            </li>
        </ul>
    </div>
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Recent orders</h2>
        @if (!canViewTradeOrders)
        {
            <p class="mt-4 text-sm text-slate-600">
                Recent orders appear here when you sign in with a trade account linked to your company.
            </p>
        }
        else if (tradeOrdersLoading)
        {
            <p class="mt-4 text-sm text-slate-500">Loading recent orders…</p>
        }
        else if (tradeOrdersError)
        {
            <p class="mt-4 text-sm text-rose-700" role="alert">We could not load your orders. Please try again later.</p>
        }
        else if (tradeOrders.Count == 0)
        {
            <p class="mt-4 text-sm text-slate-600">No orders yet. When you place an order, it will show up here.</p>
        }
        else
        {
            <div class="mt-4 overflow-x-auto">
                <table class="w-full border-collapse text-sm [&_td]:border-t [&_td]:border-slate-100 [&_td]:py-2 [&_td]:pe-3 [&_th]:pb-2 [&_th]:text-left [&_th]:text-xs [&_th]:font-semibold [&_th]:uppercase [&_th]:tracking-wide [&_th]:text-slate-500">
                    <thead>
                        <tr>
                            <th>Order</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th><span class="sr-only">Details</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in tradeOrders)
                        {
                            <tr>
                                <td class="font-medium text-slate-900">@o.OrderNumber</td>
                                <td class="text-slate-600">@o.PlacedAt.ToLocalTime().ToString("d")</td>
                                <td class="text-slate-600">@o.ItemCount</td>
                                <td class="font-medium text-slate-900">@o.Total.ToString("C")</td>
                                <td><OrderStatusBadge Status="@o.Status" /></td>
                                <td class="whitespace-nowrap">
                                    <a class="text-link text-sm font-medium hover:text-primary" href="@Routes.Store.OrderDetail(o.Id)">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        <a class="mt-4 inline-block text-sm font-medium text-link hover:text-primary" href="@Routes.Store.Orders">View all orders</a>
    </div>
</div>

@code {
    private readonly int openOrders = 2;

    private readonly decimal spend30 = 6840.12m;

    private readonly decimal creditAvailable = 25000m;

    private bool canViewTradeOrders;

    private bool tradeOrdersLoading;

    private bool tradeOrdersError;

    private IReadOnlyList<TradeOrderSummaryModel> tradeOrders = [];

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        canViewTradeOrders = CanViewTradeOrders(user);

        if (!canViewTradeOrders)
        {
            return;
        }

        tradeOrdersLoading = true;
        try
        {
            tradeOrders = await TradeOrdersApi.GetRecentAsync(8);
        }
        catch
        {
            tradeOrdersError = true;
        }
        finally
        {
            tradeOrdersLoading = false;
        }
    }

    private static bool CanViewTradeOrders(ClaimsPrincipal user)
    {
        if (user.IsInRole("SupplierAdmin") || user.IsInRole("SupplierViewer"))
        {
            return false;
        }

        return user.IsInRole("Customer") || user.IsInRole("CompanyAdmin");
    }
}
