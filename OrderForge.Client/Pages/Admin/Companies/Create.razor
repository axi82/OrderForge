@page "/admin/companies/create"
@attribute [Authorize(Policy = AuthorizationPolicies.SupplierAdmin)]
@inject IAdminApiClient AdminApi

<PageTitle>Create company</PageTitle>

<h1 class="mb-3">Create customer company</h1>

<p class="text-muted small">Creates a Keycloak organisation and a linked company record.</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}

<EditForm Model="model" OnValidSubmit="OnSubmitAsync">
    <div class="row g-2">
        <div class="col-md-6">
            <label class="form-label">Name *</label>
            <InputText class="form-control" @bind-Value="model.Name" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Trading as</label>
            <InputText class="form-control" @bind-Value="model.TradingAs" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Company number</label>
            <InputText class="form-control" @bind-Value="model.CompanyNumber" />
        </div>
        <div class="col-md-6">
            <label class="form-label">VAT number</label>
            <InputText class="form-control" @bind-Value="model.VatNumber" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Account number</label>
            <InputText class="form-control" @bind-Value="model.AccountNumber" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Status</label>
            <InputSelect class="form-select" @bind-Value="model.Status">
                <option value="Active">Active</option>
                <option value="Inactive">Inactive</option>
            </InputSelect>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary" disabled="@saving">Create</button>
        <a class="btn btn-link" href="admin/companies">Back to list</a>
    </div>
</EditForm>

@code {
    private readonly CreateCustomerCompanyRequest model = new();
    private string? errorMessage;
    private string? successMessage;
    private bool saving;

    private async Task OnSubmitAsync()
    {
        errorMessage = null;
        successMessage = null;
        saving = true;
        try
        {
            var created = await AdminApi.CreateCompanyAsync(model);
            successMessage = $"Created company #{created.Id} (Keycloak org: {created.KeycloakOrganizationId}).";
            model.Name = string.Empty;
            model.TradingAs = null;
            model.CompanyNumber = null;
            model.VatNumber = null;
            model.AccountNumber = null;
            model.Status = "Active";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            saving = false;
        }
    }
}
