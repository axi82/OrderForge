@page "/admin/companies"
@attribute [Authorize(Policy = AuthorizationPolicies.SupplierStaff)]
@inject IAdminApiClient AdminApi

<PageTitle>Companies (admin)</PageTitle>

<h1 class="mb-3">Customer companies</h1>

<p class="text-muted small">Companies linked to Keycloak organisations.</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (loading)
{
    <p class="text-muted">Loading…</p>
}
else if (items.Count == 0)
{
    <p class="text-muted">No linked companies.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-sm">
            <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Keycloak org id</th>
                <th>Status</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var o in items)
            {
                <tr>
                    <td>@o.Id</td>
                    <td>@o.Name</td>
                    <td><code class="small">@(o.KeycloakOrganizationId ?? "—")</code></td>
                    <td>@o.Status</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    private readonly List<OrganisationDto> items = [];
    private bool loading = true;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items.Clear();
            items.AddRange(await AdminApi.GetCompaniesAsync());
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
