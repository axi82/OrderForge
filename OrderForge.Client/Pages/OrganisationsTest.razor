@page "/organisations-test"
@attribute [Authorize]
@inject IOrganisationsApiClient OrganisationsApi
@inject IJSRuntime Js

<PageTitle>Organisations test</PageTitle>

<h1 class="mb-3 text-2xl font-semibold">
    Organisations <span class="text-xl font-normal text-gray-500">(test page)</span>
</h1>

<p class="text-sm text-gray-500">
    API base URL comes from configuration → <code>ApiBaseUrl</code> (Aspire sets this for you). You must be signed in; requests send a JWT Bearer token.
</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="mt-4 rounded-md border border-red-200 bg-red-50 px-4 py-3 text-red-800" role="alert">
        <pre class="mb-0 text-wrap text-sm">@errorMessage</pre>
    </div>
}

<div class="mb-4 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="border-b border-gray-200 bg-gray-50 px-4 py-3 font-medium text-gray-900">
        @(editingId is null ? "Add organisation" : $"Edit organisation #{editingId}")
    </div>
    <div class="p-4">
        <div class="-mx-2 flex flex-wrap gap-y-2">
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Name *</label>
                <input
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.Name"
                />
            </div>
            <div class="w-full px-2 md:w-1/2">
                <label class="mb-1 block text-sm font-medium text-gray-700">Trading as</label>
                <input
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.TradingAs"
                />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Company number</label>
                <input
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.CompanyNumber"
                />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">VAT number</label>
                <input
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.VatNumber"
                />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Account number</label>
                <input
                    class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.AccountNumber"
                />
            </div>
            <div class="w-full px-2 md:w-1/3">
                <label class="mb-1 block text-sm font-medium text-gray-700">Status *</label>
                <select
                    class="w-full rounded-md border border-gray-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
                    @bind="form.Status"
                >
                    @foreach (var s in StatusOptions)
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
            <button
                type="button"
                class="rounded-md bg-accent px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-accent-dark focus:outline-none focus:ring-2 focus:ring-accent-ring disabled:opacity-50"
                disabled="@busy"
                @onclick="SaveAsync"
            >
                @(editingId is null ? "Create" : "Save changes")
            </button>
            @if (editingId is not null)
            {
                <button
                    type="button"
                    class="rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-300 disabled:opacity-50"
                    disabled="@busy"
                    @onclick="CancelEdit"
                >
                    Cancel edit
                </button>
            }
        </div>
    </div>
</div>

@if (loadingList)
{
    <p class="text-gray-500">Loading list…</p>
}
else if (items.Count == 0)
{
    <p class="text-gray-500">No organisations returned.</p>
}
else
{
    <div class="overflow-x-auto">
        <table
            class="w-full border-collapse text-sm align-middle [&_tbody_tr:nth-child(odd)]:bg-gray-50 [&_td]:border-b [&_td]:border-gray-200 [&_td]:px-3 [&_td]:py-2 [&_th]:border-b [&_th]:border-gray-300 [&_th]:bg-gray-100 [&_th]:px-3 [&_th]:py-2 [&_th]:text-left"
        >
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Name</th>
                    <th>Trading as</th>
                    <th>Status</th>
                    <th>Account #</th>
                    <th>Updated</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in items)
                {
                    <tr>
                        <td>@o.Id</td>
                        <td>@o.Name</td>
                        <td>@(o.TradingAs ?? "—")</td>
                        <td>
                            <span class="inline-flex rounded-full bg-gray-600 px-2 py-0.5 text-xs font-medium text-white">
                                @o.Status
                            </span>
                        </td>
                        <td>@(o.AccountNumber ?? "—")</td>
                        <td class="text-sm text-gray-500">@o.UpdatedAt.ToLocalTime().ToString("g")</td>
                        <td class="whitespace-nowrap">
                            <button
                                type="button"
                                class="me-1 rounded-md border border-primary bg-white px-2 py-1 text-xs font-medium text-primary shadow-sm hover:bg-primary/5 focus:outline-none focus:ring-2 focus:ring-primary/30 disabled:opacity-50"
                                disabled="@busy"
                                @onclick="() => StartEdit(o)"
                            >
                                Edit
                            </button>
                            <button
                                type="button"
                                class="rounded-md border border-red-600 bg-white px-2 py-1 text-xs font-medium text-red-600 shadow-sm hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-300 disabled:opacity-50"
                                disabled="@busy"
                                @onclick="() => DeleteAsync(o)"
                            >
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private static readonly string[] StatusOptions = ["Active", "Inactive", "Unknown"];

    private readonly OrganisationFormState form = new();

    private List<OrganisationDto> items = [];

    private int? editingId;

    private bool loadingList = true;

    private bool busy;

    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await RefreshListAsync();
    }

    private async Task RefreshListAsync()
    {
        loadingList = true;
        errorMessage = null;
        try
        {
            items = (await OrganisationsApi.GetAllAsync()).ToList();
        }
        catch (Exception ex)
        {
            errorMessage = FormatError(ex);
            items = [];
        }
        finally
        {
            loadingList = false;
            StateHasChanged();
        }
    }

    private void StartEdit(OrganisationDto o)
    {
        editingId = o.Id;
        form.Name = o.Name;
        form.TradingAs = o.TradingAs;
        form.CompanyNumber = o.CompanyNumber;
        form.VatNumber = o.VatNumber;
        form.AccountNumber = o.AccountNumber;
        form.Status = o.Status;
        errorMessage = null;
    }

    private void CancelEdit()
    {
        editingId = null;
        form.Clear();
        errorMessage = null;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(form.Name))
        {
            errorMessage = "Name is required.";
            return;
        }

        busy = true;
        errorMessage = null;
        try
        {
            if (editingId is null)
            {
                var req = new CreateOrganisationRequest
                {
                    Name = form.Name.Trim(),
                    TradingAs = NullIfEmpty(form.TradingAs),
                    CompanyNumber = NullIfEmpty(form.CompanyNumber),
                    VatNumber = NullIfEmpty(form.VatNumber),
                    AccountNumber = NullIfEmpty(form.AccountNumber),
                    Status = form.Status
                };
                await OrganisationsApi.CreateAsync(req);
            }
            else
            {
                var req = new UpdateOrganisationRequest
                {
                    Name = form.Name.Trim(),
                    TradingAs = NullIfEmpty(form.TradingAs),
                    CompanyNumber = NullIfEmpty(form.CompanyNumber),
                    VatNumber = NullIfEmpty(form.VatNumber),
                    AccountNumber = NullIfEmpty(form.AccountNumber),
                    Status = form.Status
                };
                await OrganisationsApi.UpdateAsync(editingId.Value, req);
            }

            CancelEdit();
            await RefreshListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = FormatError(ex);
        }
        finally
        {
            busy = false;
            StateHasChanged();
        }
    }

    private async Task DeleteAsync(OrganisationDto o)
    {
        if (!await Js.InvokeAsync<bool>("confirm", $"Delete organisation \"{o.Name}\" (id {o.Id})?"))
        {
            return;
        }

        busy = true;
        errorMessage = null;
        try
        {
            await OrganisationsApi.DeleteAsync(o.Id);
            if (editingId == o.Id)
            {
                CancelEdit();
            }

            await RefreshListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = FormatError(ex);
        }
        finally
        {
            busy = false;
            StateHasChanged();
        }
    }

    private static string? NullIfEmpty(string? s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

    private static string FormatError(Exception ex) =>
        ex switch
        {
            OrganisationsApiException api => api.ResponseBody ?? api.Message,
            _ => ex.Message
        };

    private sealed class OrganisationFormState
    {
        public string Name { get; set; } = string.Empty;

        public string? TradingAs { get; set; }

        public string? CompanyNumber { get; set; }

        public string? VatNumber { get; set; }

        public string? AccountNumber { get; set; }

        public string Status { get; set; } = "Active";

        public void Clear()
        {
            Name = string.Empty;
            TradingAs = null;
            CompanyNumber = null;
            VatNumber = null;
            AccountNumber = null;
            Status = "Active";
        }
    }
}
