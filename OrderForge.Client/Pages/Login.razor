@page "/login"
@inject NavigationManager Navigation
@inject IConfiguration Configuration

<PageTitle>Sign in</PageTitle>

<h1>Sign in</h1>

<p class="text-gray-500">
    You will be redirected to Keycloak to sign in with your email and password.
</p>

<p class="text-sm text-gray-500">
    <strong>Remember me:</strong> use the <em>Remember me</em> checkbox on the Keycloak sign-in page for a longer session (realm also has SSO timeouts — see AppHost Keycloak comments).
</p>

<div class="flex flex-col items-start gap-2">
    <button
        type="button"
        class="rounded-md bg-primary px-4 py-2 text-sm font-medium text-white shadow-sm hover:bg-primary-dark focus:outline-none focus:ring-2 focus:ring-primary-ring disabled:opacity-50"
        @onclick="BeginLogin"
    >
        Sign in
    </button>
    @if (!string.IsNullOrEmpty(forgotPasswordUrl))
    {
        <a class="text-primary hover:text-primary-dark hover:underline" href="@forgotPasswordUrl" target="_blank" rel="noopener noreferrer">Forgot password?</a>
    }
</div>

@code {
    private string? forgotPasswordUrl;

    protected override void OnInitialized()
    {
        var baseUrl = Configuration["Keycloak:AuthServerUrl"]?.TrimEnd('/');
        var realm = Configuration["Keycloak:Realm"];
        var clientId = Configuration["Keycloak:ForgotPasswordClientId"] ?? "orderforge-blazor";
        if (!string.IsNullOrEmpty(baseUrl) && !string.IsNullOrEmpty(realm))
        {
            var redirect = Uri.EscapeDataString(Navigation.BaseUri.TrimEnd('/'));
            forgotPasswordUrl =
                $"{baseUrl}/realms/{realm}/login-actions/reset-credentials?client_id={Uri.EscapeDataString(clientId)}&redirect_uri={redirect}";
        }
    }

    private void BeginLogin()
    {
        Navigation.NavigateTo("authentication/login?returnUrl=" + Uri.EscapeDataString("dashboard"));
    }
}
