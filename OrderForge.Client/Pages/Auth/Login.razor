@page "/auth/login"
@layout EmptyLayout
@inject NavigationManager Navigation
@inject AppNavigator Navigator
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Sign in</PageTitle>

<div class="flex min-h-screen flex-col bg-slate-50">
    <header class="border-b border-slate-200 bg-white">
        <div class="mx-auto flex max-w-screen-2xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
            <a class="text-lg font-semibold tracking-tight text-primary no-underline hover:text-primary-dark" href="@Routes.App.Root">Order Forge</a>
        </div>
    </header>
    <main class="flex flex-1 items-center justify-center px-4 py-16">
        <p class="text-sm text-slate-600" role="status">@statusMessage</p>
    </main>
</div>

@code {
    private string statusMessage = "Signing in…";

    protected override async Task OnInitializedAsync()
    {
        var returnUrl = TryGetQueryValue(Navigation.ToAbsoluteUri(Navigation.Uri), "returnUrl") ?? Routes.Auth.PostLogin;
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync().ConfigureAwait(false);
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo(returnUrl);
            return;
        }

        Navigator.BeginOidcSignIn(returnUrl);
    }

    private static string? TryGetQueryValue(Uri uri, string name)
    {
        var q = uri.Query;
        if (string.IsNullOrEmpty(q) || q[0] != '?')
        {
            return null;
        }

        var prefix = name + "=";
        ReadOnlySpan<char> tail = q.AsSpan(1);
        while (!tail.IsEmpty)
        {
            var amp = tail.IndexOf('&');
            var pair = amp >= 0 ? tail[..amp] : tail;
            if (pair.StartsWith(prefix.AsSpan(), StringComparison.OrdinalIgnoreCase))
            {
                var raw = pair[prefix.Length..];
                return Uri.UnescapeDataString(raw.ToString());
            }

            tail = amp >= 0 ? tail[(amp + 1)..] : ReadOnlySpan<char>.Empty;
        }

        return null;
    }
}
