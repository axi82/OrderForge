@page "/authentication/login-failed"
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

<PageTitle>Sign-in failed</PageTitle>

<h1>Sign-in failed</h1>

<p class="text-red-600">
    We could not complete sign-in. Your email or password may be incorrect, or the sign-in was cancelled.
</p>

<p>
    <a class="text-primary hover:text-primary-dark hover:underline" href="login">Try again</a>
    <span class="text-gray-400">&nbsp;·&nbsp;</span>
    <a class="text-primary hover:text-primary-dark hover:underline" href="">Go home</a>
</p>
