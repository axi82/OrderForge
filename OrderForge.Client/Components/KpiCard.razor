<div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md">
    <p class="text-sm font-medium text-slate-500">@Title</p>
    <p class="mt-2 text-2xl font-semibold tracking-tight text-slate-900">@Value</p>
    @if (!string.IsNullOrEmpty(Note))
    {
        <p class="mt-1 text-sm text-slate-500">@Note</p>
    }
</div>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public string? Note { get; set; }
}
